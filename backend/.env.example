# Server Configuration
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Upload Settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp

# Model Settings
DEVICE=cpu
MODEL_CACHE_DIR=./models
ENABLE_STABLE_DIFFUSION=false
STABLE_DIFFUSION_MODEL=runwayml/stable-diffusion-v1-5

# Advanced AI Features
ENABLE_GEMINI=false
ENABLE_CONTROLNET=false
ENABLE_SDXL=false

# API Keys (if needed)
HUGGINGFACE_TOKEN=
GEMINI_API_KEY=

# Multi-Engine AI Generation API Keys
# OpenAI DALL-E 3 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Replicate API (https://replicate.com/account/api-tokens)
REPLICATE_API_KEY=
# Optional: override default Replicate model (default: black-forest-labs/flux-schnell)
REPLICATE_MODEL=

# HuggingFace Inference API – uses HUGGINGFACE_TOKEN above
# Optional: override the HuggingFace model (default: stabilityai/stable-diffusion-xl-base-1.0)
HF_MODEL=
